#!/usr/bin/env bash
# cdr-header — emit CF Access service-token headers in the
# 'key=value' format that the Coder VS Code extension's
# 'Coder: Header Command' setting expects.
#
# Setup (one-time, in VS Code):
#   1. Settings (Cmd+, on macOS) -> search 'Coder: Header Command'
#   2. Set the value to the absolute path of THIS script:
#        /Users/<you>/dotfiles/exe/scripts/cdr-header
#      (or symlinked at ~/.local/bin/cdr-header — see
#      'just exe-cdr-install' which puts both 'cdr' and
#      'cdr-header' on PATH).
#   3. The CODER_URL env is provided by the extension at invocation
#      time; this script ignores it (only one Coder URL is
#      supported by this stack — exe.hironow.dev).
#
# Behaviour mirrors exe/scripts/cdr: pull the service-token
# credentials from Secret Manager, cache for 5 min in
# ~/.cache/exe-coder-cli/, then emit them. Any extension /
# coder-cli-derived caller that wants the header can shell out to
# this script.

set -euo pipefail

# VS Code spawned from a GUI (Dock / Spotlight) inherits the
# minimal launchd PATH (/usr/bin:/bin:/usr/sbin:/sbin) so 'gcloud'
# from Homebrew or the Cloud SDK install dir is invisible. Prepend
# the locations operators actually install gcloud into. Order:
# Apple Silicon Homebrew, Intel Homebrew, manual ~/.local/bin,
# ~/google-cloud-sdk/bin (the SDK installer's default), then the
# pre-existing PATH.
PATH="/opt/homebrew/bin:/usr/local/bin:${HOME}/.local/bin:${HOME}/google-cloud-sdk/bin:${PATH:-/usr/bin:/bin}"
export PATH

CACHE_DIR="${HOME}/.cache/exe-coder-cli"
CACHE_TTL_SEC="${CDR_CACHE_TTL_SEC:-300}"

err() { printf '[cdr-header] %s\n' "$*" >&2; exit 1; }

require() {
  command -v "$1" >/dev/null 2>&1 || err "missing required tool: $1 (PATH=$PATH)"
}

require gcloud

mkdir -p "${CACHE_DIR}"
chmod 0700 "${CACHE_DIR}"

file_mtime() {
  local f="$1"
  if [[ "$(uname)" == "Darwin" ]]; then
    stat -f %m "$f"
  else
    stat -c %Y "$f"
  fi
}

refresh_secret_if_stale() {
  local file="$1" secret_name="$2"
  if [[ ! -f "${file}" ]] \
     || [[ $(( $(date +%s) - $(file_mtime "${file}") )) -gt ${CACHE_TTL_SEC} ]]; then
    gcloud secrets versions access latest --secret="${secret_name}" \
      > "${file}.tmp"
    chmod 0600 "${file}.tmp"
    mv "${file}.tmp" "${file}"
  fi
}

refresh_secret_if_stale "${CACHE_DIR}/client_id"     "exe-coder-cli-client-id"
refresh_secret_if_stale "${CACHE_DIR}/client_secret" "exe-coder-cli-client-secret"

printf "CF-Access-Client-Id=%s\n"     "$(<"${CACHE_DIR}/client_id")"
printf "CF-Access-Client-Secret=%s\n" "$(<"${CACHE_DIR}/client_secret")"
