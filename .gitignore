# Homebrew
Brewfile.lock.json

# dotfiles-specific private
refs/
.env.keys

# node lockfiles (not tracked in dotfiles)
package.json
package-lock.json
bun.lock

# autodesign
design-results.tsv
design-config.yaml
run.log

# Azure
.azurite/

# IaC
# Terraform/OpenTofu lockfiles ARE committed (HashiCorp recommends
# this for provider reproducibility). The runtime cache dir
# `.terraform/` and state files stay ignored.
.terraform
*.tfstate
terraform.tfstate
terraform.tfstate.backup
*.tfplan

# exe.hironow.dev — local secrets / generated runtime files
# (real values live in GCP Secret Manager; never commit plaintext)
exe/**/*.local.*
exe/cloudflared/cert.pem
exe/cloudflared/*.json
exe/tailscale/*.authkey
tofu/exe/terraform.tfvars
tofu/exe/*.auto.tfvars

# Cargo
/target/

# AI coding
.serena/cache/
.sync-manifest.json

# Model
*.pt

# claude local settings (broader than global)
.claude/*.local.*

# paintress expedition state
journal.tsv
gradient.json
lumina.md
gommage.md
continent-config.yaml

# coding agents
.pi/

# Per-session intent + handover for AI agents (CLAUDE.md exempts these
# from "current state only" but they are intentionally not committed).
docs/intent.md
docs/handover.md
docs/setup.md
node_modules
