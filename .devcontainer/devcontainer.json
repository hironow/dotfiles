// Dev Container Specification — https://containers.dev
//
// Single source of truth shared by three consumers:
//   1. local IDE   — VS Code / Cursor / JetBrains "Reopen in Container"
//   2. CI sandbox  — `devcontainers/ci` action in test-just.yaml
//   3. Coder workspace — envbuilder reads this file on workspace boot
//
// Trust policy (see ADR 0001):
//   - features: ONLY Microsoft-curated `ghcr.io/devcontainers/features/*`
//   - everything else (gcloud, just, mise, uv) is installed by the
//     **vendor's own upstream installer** in onCreateCommand. No
//     community features in the dependency graph.
{
  "name": "dotfiles",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false,
      "installOhMyZsh": false,
      "username": "root",
      "uid": "automatic",
      "gid": "automatic"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "installTools": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  "remoteUser": "root",
  "containerUser": "root",

  "workspaceFolder": "/root/dotfiles",
  "workspaceMount": "source=${localWorkspaceFolder},target=/root/dotfiles,type=bind,consistency=cached",

  // Vendor-official installers for tools not covered by Microsoft
  // features. Each line uses the upstream-published installer from
  // the project's own domain, so the trust boundary is the vendor.
  //   - gcloud : Google Cloud SDK (sdk.cloud.google.com)
  //   - mise   : jdx/mise (mise.run)
  //   - uv     : Astral (astral.sh)
  //   - just   : casey/just GitHub release tarball (musl-free debian binary)
  //   - sheldon: rossmacarthur/sheldon GitHub release tarball
  //
  // Then mise install resolves mise.toml tools (markdownlint-cli2,
  // prek, vp, ...) and just install-hooks wires prek into git.
  // Runs once per container creation; devcontainers/ci pre-bakes it
  // into the cached image so CI reuses the result.
  "onCreateCommand": "bash .devcontainer/post-create.sh",

  // install-hooks wires prek into .git/hooks for this clone. Must run
  // after onCreate so just/mise are on PATH.
  "postCreateCommand": "just install-hooks",

  "containerEnv": {
    "MISE_OFFLINE": "1",
    "PATH": "/root/.local/bin:/root/.local/share/mise/shims:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "timonwong.shellcheck",
        "DavidAnson.vscode-markdownlint",
        "skellock.just",
        "hverlin.mise-vscode",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  }
}
